{
    "name": "NicoIIT/esphome-components",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--group-add=20", // dialout group, needed to access USB Devices
        "--device=/dev/ttyUSB0" // USB Device access, to be added / uncommented / changed IF you have a USB Device connected
    ],
    "mounts": [
        // External configs, as you can also use esphome directly to handle your configs
        "source=/data/esphome/config,target=/config,type=bind,consistency=cached"
    ],
    "postCreateCommand": [
        ".devcontainer/post-create",
        "${containerWorkspaceFolder}/base_config/c3-idf.yaml" // Base config used to compute C++ settings
    ],
    "remoteUser": "esphome",
    "containerEnv": {
        "ESPHOME_DASHBOARD_USE_PING": "1",
        "PLATFORMIO_CORE_DIR": "${containerWorkspaceFolder}/.cache/.pio",
        "PLATFORMIO_GLOBALLIB_DIR": "${containerWorkspaceFolder}/.cache/.piolibs",
        "PIP_CACHE_DIR": "${containerWorkspaceFolder}/.cache/.pip_cache",
        "SHELL": "/bin/bash"
    },
    "forwardPorts": [
        6052
    ],
    "portsAttributes": {
        "6052": {
            "label": "ESPHome",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "charliermarsh.ruff",
                "github.vscode-pull-request-github",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ryanluker.vscode-coverage-gutters",
                "ms-vscode.cpptools"
            ],
            "settings": {
                "files.eol": "\n",
                "editor.tabSize": 4,
                "editor.formatOnPaste": true,
                "editor.formatOnSave": true,
                "editor.formatOnType": false,
                "files.trimTrailingWhitespace": true,
                "python.analysis.typeCheckingMode": "basic",
                "python.analysis.autoImportCompletions": true,
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                }
            }
        }
    }
}